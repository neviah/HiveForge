{
  "llm": {
    "provider": "lmstudio",
    "endpoint": "http://127.0.0.1:1234/api/v1",
    "model": null,
    "streaming": true,
    "cloudProviders": false,
    "remoteTools": false
  },
  "sandbox": {
    "workspace": "/sandbox/workspace",
    "allowedReadRoots": [
      "/sandbox/workspace",
      "/sandbox/config.json",
      "__BUNDLED_OPENCLAW_PATH__"
    ],
    "allowedWriteRoot": "/sandbox/workspace"
  },
  "git": {
    "user": {
      "name": "HiveForge Agent",
      "email": "HiveForge@sandbox.local"
    },
    "sshKeyPath": "/sandbox/.ssh/id_rsa"
  },
  "skills": {
    "policyFile": "/sandbox/skills/sandbox_policy.json",
    "requireSkillVetter": true,
    "allowHostFilesystemAccess": false,
    "allowDirectCredentialAccess": false,
    "coordinatorMediatedOnly": true
  }
}
