{
  "version": "1.0.0",
  "default": {
    "allow": false,
    "reason": "deny-by-default"
  },
  "global_rules": {
    "allow_host_filesystem_access": false,
    "allow_direct_credential_access": false,
    "require_coordinator_mediation": true,
    "require_audit_logging": true,
    "workspace_roots": [
      "sandbox/workspace",
      "sandbox/agents",
      "sandbox/credentials",
      "webui"
    ]
  },
  "skills": {
    "skill-vetter": {
      "enabled": true,
      "risk_level": "low",
      "allowed_network_domains": [],
      "allowed_paths": [
        "skills",
        "docs"
      ],
      "blocked_paths": [
        "sandbox/credentials/*.enc"
      ]
    },
    "self-improving-agent": {
      "enabled": true,
      "risk_level": "medium",
      "allowed_network_domains": [],
      "allowed_paths": [
        "sandbox/workspace",
        "sandbox/agents",
        "docs"
      ],
      "blocked_paths": [
        "sandbox/credentials/*.enc"
      ]
    },
    "proactive-agent": {
      "enabled": true,
      "risk_level": "medium",
      "allowed_network_domains": [],
      "allowed_paths": [
        "agents",
        "sandbox/agents",
        "docs"
      ],
      "blocked_paths": [
        "sandbox/credentials/*.enc"
      ]
    },
    "github": {
      "enabled": true,
      "risk_level": "medium",
      "allowed_network_domains": [
        "api.github.com",
        "github.com"
      ],
      "allowed_paths": [
        ".git",
        "docs",
        "webui",
        "agents",
        "templates",
        "sandbox"
      ],
      "blocked_paths": [
        "sandbox/credentials/*.enc"
      ],
      "repo_allowlist": [
        "neviah/HiveForge"
      ]
    },
    "agent-browser": {
      "enabled": false,
      "risk_level": "high",
      "allowed_network_domains": [],
      "allowed_paths": [
        "sandbox/workspace",
        "webui"
      ],
      "blocked_paths": [
        "sandbox/credentials/*"
      ],
      "notes": "Disabled by default due to installer warning; enable only after explicit review."
    },
    "api-gateway": {
      "enabled": true,
      "risk_level": "high",
      "coordinator_only": true,
      "allowed_network_domains": [
        "gateway.maton.ai",
        "ctrl.maton.ai"
      ],
      "allowed_paths": [
        "sandbox/credentials",
        "agents"
      ],
      "blocked_paths": [
        "sandbox/credentials/*.enc"
      ],
      "required_env": [
        "MATON_API_KEY"
      ]
    }
  }
}
