{
    "template_id":  "game_studio",
    "display_name":  "Game Studio (2D Web-First)",
    "version":  "1.0.0",
    "goal_definition":  "Ship a playable 2D web-first game with automated Netlify test deployments, placeholder primitive assets, human-art handoff, and release-ready tracks for itch.io and Steam.",
    "coordinator_agent":  {
                              "required":  true,
                              "role":  "Coordinator Agent",
                              "system_prompt_profile":  "hiveforge_coordinator_v1",
                              "system_prompt_path":  "agents/prompts/coordinator_system_prompt.md"
                          },
    "subordinate_agents":  [
                               {
                                   "role":  "Creative Director",
                                   "alias":  "Studio Producer",
                                   "required":  true,
                                   "personality_prompt_paths":  [
                                                                    "../agency-agents/project-management/project-management-studio-producer.md"
                                                                ]
                               },
                               {
                                   "role":  "Game Designer",
                                   "required":  true,
                                   "personality_prompt_paths":  [
                                                                    "../agency-agents/game-development/game-designer.md"
                                                                ]
                               },
                               {
                                   "role":  "Developer",
                                   "alias":  "Backend Architect",
                                   "required":  true,
                                   "personality_prompt_paths":  [
                                                                    "../agency-agents/engineering/engineering-backend-architect.md"
                                                                ]
                               },
                               {
                                   "role":  "Artist",
                                   "alias":  "UI Designer",
                                   "required":  true,
                                   "personality_prompt_paths":  [
                                                                    "../agency-agents/design/design-ui-designer.md"
                                                                ]
                               },
                               {
                                   "role":  "Sound Designer",
                                   "alias":  "Game Audio Engineer",
                                   "required":  true,
                                   "personality_prompt_paths":  [
                                                                    "../agency-agents/game-development/game-audio-engineer.md"
                                                                ]
                               },
                               {
                                   "role":  "QA",
                                   "alias":  "Evidence Collector",
                                   "required":  true,
                                   "personality_prompt_paths":  [
                                                                    "../agency-agents/testing/testing-evidence-collector.md"
                                                                ]
                               },
                               {
                                   "role":  "Community Manager",
                                   "alias":  "Social Media Strategist",
                                   "required":  true,
                                   "personality_prompt_paths":  [
                                                                    "../agency-agents/marketing/marketing-social-media-strategist.md"
                                                                ]
                               }
                           ],
    "optional_agents":  [
                            "Narrative Designer",
                            "Level Designer",
                            "Technical Artist",
                            "Multiplayer Network Engineer",
                            "Reality Checker",
                            "Feedback Synthesizer",
                            "Sprint Prioritizer"
                        ],
    "operating_mode":  "finite_delivery",
    "recurring_loops":  [
                            {
                                "key":  "studio_liveops_review",
                                "title":  "Review build health and player issue backlog",
                                "phase":  "qa",
                                "owner_role":  "Evidence Collector",
                                "every_ms":  21600000,
                                "enabled":  true
                            },
                            {
                                "key":  "studio_netlify_test_deploy",
                                "title":  "Trigger Netlify test deployment and publish smoke-check notes",
                                "phase":  "release",
                                "owner_role":  "Studio Producer",
                                "every_ms":  28800000,
                                "action":  {
                                    "type":  "connector",
                                    "connector":  "netlify",
                                    "operation":  "trigger_deploy",
                                    "estimated_cost":  0,
                                    "requires_permission":  true,
                                    "input":  {
                                        "siteId":  "{{netlify_site_id}}"
                                    }
                                },
                                "enabled":  true
                            },
                            {
                                "key":  "studio_multiplayer_cost_guardrail",
                                "title":  "Review P2P session health, relay usage, and cost guardrails",
                                "phase":  "analysis",
                                "owner_role":  "Studio Producer",
                                "every_ms":  21600000,
                                "enabled":  true
                            }
                        ],
    "auto_staffing_policy":  {
                                 "enabled":  true,
                                 "cooldown_minutes":  60,
                                 "backlog_per_agent_threshold":  3,
                                 "max_optional_adds":  3,
                                 "max_agents":  13
                             },
    "workflow_definition":  {
                                "phases":  [
                                            "concept",
                                            "prototype",
                                            "production",
                                            "qa",
                                            "release"
                                           ],
                                "heartbeat_enabled":  true
                            },
                "asset_strategy":  {
                                       "bootstrap_mode":  "primitive_squares_and_shapes",
                                       "human_art_handoff_required":  true,
                                       "handoff_directory":  "workspace/assets/final_art"
                                   },
                "release_tracks":  [
                                       {
                                           "id":  "itch_io_web",
                                           "title":  "itch.io Web Track",
                                           "target":  "html5",
                                           "deploy_source":  "netlify_test_build"
                                       },
                                       {
                                           "id":  "steam_desktop",
                                           "title":  "Steam Desktop Track",
                                           "target":  "desktop_wrapper",
                                           "deploy_source":  "electron_or_tauri_package"
                                       }
                                   ],
                "multiplayer_strategy":  {
                                             "default_mode":  "p2p_listen_server",
                                             "host_migration_required":  true,
                                             "relay_fallback":  "only_when_direct_connection_fails",
                                             "notes":  "Use P2P by default to minimize hosting cost, with coordinator escalation when relay spend rises."
                                         },
    "task_breakdown":  [
                           {
                               "id":  "GAME-1",
                                           "title":  "Define 2D web-first scope, core loop, and P2P multiplayer assumptions",
                               "phase":  "concept"
                           },
                           {
                               "id":  "GAME-2",
                                           "title":  "Build vertical-slice prototype using placeholder squares/shapes UI and sprites",
                               "phase":  "prototype"
                           },
                           {
                               "id":  "GAME-3",
                                           "title":  "Automate Netlify test deploy lane and telemetry smoke checks",
                               "phase":  "production"
                           },
                           {
                               "id":  "GAME-4",
                                           "title":  "Integrate human-delivered art/audio assets and execute QA matrix",
                               "phase":  "qa"
                           },
                           {
                               "id":  "GAME-5",
                                           "title":  "Ship release lanes for itch.io web build and Steam desktop packaging",
                               "phase":  "release"
                           }
                       ],
    "dependency_graph":  {
                             "GAME-1":  [

                                        ],
                             "GAME-2":  [
                                            "GAME-1"
                                        ],
                             "GAME-3":  [
                                            "GAME-2"
                                        ],
                             "GAME-4":  [
                                            "GAME-3"
                                        ],
                             "GAME-5":  [
                                            "GAME-4"
                                        ]
                         }
}

