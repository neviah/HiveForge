{
    "template_id":  "game_studio",
    "display_name":  "Game Studio (2D Web-First)",
    "version":  "1.0.0",
    "goal_definition":  "Ship a playable 2D web-first game with a polished single-player core loop, optional P2P multiplayer, automated Netlify test deployments, placeholder primitive assets, human-art handoff, and release-ready tracks for itch.io and Steam.",
    "coordinator_agent":  {
                              "required":  true,
                              "role":  "Coordinator Agent",
                              "system_prompt_profile":  "hiveforge_coordinator_v1",
                              "system_prompt_path":  "agents/prompts/coordinator_system_prompt.md"
                          },
    "subordinate_agents":  [
                               {
                                   "role":  "Creative Director",
                                   "alias":  "Studio Producer",
                                   "required":  true,
                                   "personality_prompt_paths":  [
                                                                    "agency-agents/project-management/project-management-studio-producer.md"
                                                                ]
                               },
                               {
                                   "role":  "Game Designer",
                                   "required":  true,
                                   "personality_prompt_paths":  [
                                                                    "agency-agents/game-development/game-designer.md"
                                                                ]
                               },
                               {
                                   "role":  "Developer",
                                   "alias":  "Backend Architect",
                                   "required":  true,
                                   "personality_prompt_paths":  [
                                                                    "agency-agents/engineering/engineering-backend-architect.md"
                                                                ]
                               },
                               {
                                   "role":  "Artist",
                                   "alias":  "UI Designer",
                                   "required":  true,
                                   "personality_prompt_paths":  [
                                                                    "agency-agents/design/design-ui-designer.md"
                                                                ]
                               },
                               {
                                   "role":  "Sound Designer",
                                   "alias":  "Game Audio Engineer",
                                   "required":  true,
                                   "personality_prompt_paths":  [
                                                                    "agency-agents/game-development/game-audio-engineer.md"
                                                                ]
                               },
                               {
                                   "role":  "QA",
                                   "alias":  "Evidence Collector",
                                   "required":  true,
                                   "personality_prompt_paths":  [
                                                                    "agency-agents/testing/testing-evidence-collector.md"
                                                                ]
                               },
                               {
                                   "role":  "Community Manager",
                                   "alias":  "Social Media Strategist",
                                   "required":  true,
                                   "personality_prompt_paths":  [
                                                                    "agency-agents/marketing/marketing-social-media-strategist.md"
                                                                ]
                               }
                           ],
    "optional_agents":  [
                            "Narrative Designer",
                            "Level Designer",
                            "Technical Artist",
                            "Multiplayer Network Engineer",
                            "Reality Checker",
                            "Feedback Synthesizer",
                            "Sprint Prioritizer"
                        ],
    "role_capabilities":  {
                              "Backend Architect":  {
                                                          "can_deploy":  true,
                                                          "can_spend":  false,
                                                          "allowed_connectors":  [
                                                                                     "github",
                                                                                     "netlify",
                                                                                     "supabase"
                                                                                 ]
                                                      }
                          },
    "operating_mode":  "finite_delivery",
    "recurring_loops":  [
                            {
                                "key":  "studio_liveops_review",
                                "title":  "Review build health and player issue backlog",
                                "phase":  "qa",
                                "owner_role":  "Evidence Collector",
                                "every_ms":  21600000,
                                "enabled":  true
                            },
                            {
                                "key":  "studio_netlify_test_deploy",
                                "title":  "Trigger Netlify test deployment and publish smoke-check notes",
                                "phase":  "release",
                                "owner_role":  "Backend Architect",
                                "every_ms":  28800000,
                                "action":  {
                                    "type":  "connector",
                                    "connector":  "netlify",
                                    "operation":  "trigger_deploy",
                                    "estimated_cost":  0,
                                    "requires_permission":  true,
                                    "input":  {
                                        "siteId":  "{{netlify_site_id}}"
                                    }
                                },
                                "enabled":  true
                            },
                            {
                                "key":  "studio_multiplayer_cost_guardrail",
                                "title":  "Review P2P session health, relay usage, and cost guardrails",
                                "phase":  "analysis",
                                "owner_role":  "Studio Producer",
                                "every_ms":  21600000,
                                "enabled":  true
                            }
                        ],
    "auto_staffing_policy":  {
                                 "enabled":  true,
                                 "cooldown_minutes":  60,
                                 "backlog_per_agent_threshold":  3,
                                 "max_optional_adds":  3,
                                 "max_agents":  13
                             },
    "workflow_definition":  {
                                "phases":  [
                                            "concept",
                                            "prototype",
                                            "production",
                                            "qa",
                                            "release"
                                           ],
                                "heartbeat_enabled":  true
                            },
                "asset_strategy":  {
                                       "bootstrap_mode":  "ai_generated_svg_assets",
                                       "all_assets_must_be_used_in_gameplay":  true,
                                       "required_assets":  [
                                           "player-sprite.svg",
                                           "enemy-sprite.svg",
                                           "tileset.svg",
                                           "ui-icon-set.svg",
                                           "promo-keyart.svg"
                                       ],
                                       "human_art_handoff_required":  false,
                                       "handoff_directory":  "workspace/assets/final_art"
                                   },
                "release_tracks":  [
                                       {
                                           "id":  "itch_io_web",
                                           "title":  "itch.io Web Track",
                                           "target":  "html5",
                                           "deploy_source":  "netlify_test_build"
                                       },
                                       {
                                           "id":  "steam_desktop",
                                           "title":  "Steam Desktop Track",
                                           "target":  "desktop_wrapper",
                                           "deploy_source":  "electron_or_tauri_package"
                                       }
                                   ],
                "multiplayer_strategy":  {
                                             "single_player_first":  true,
                                             "default_mode":  "single_player",
                                             "optional_multiplayer_mode":  "p2p_listen_server",
                                             "host_migration_required":  true,
                                             "relay_fallback":  "only_when_direct_connection_fails",
                                             "notes":  "Ship single-player first, then add optional P2P multiplayer to minimize hosting cost, with coordinator escalation when relay spend rises."
                                         },
    "task_breakdown":  [
                           {
                               "id": "GAME-1",
                               "title": "Write Game Design Document (GDD) — genre, core loop, entities, scoring, win/lose conditions",
                               "phase": "concept",
                               "owner_role": "Game Designer",
                               "required_outputs": [
                                   "GDD.md in workspace root with genre, player goals, entity descriptions, scoring rules, win condition, game-over condition, and difficulty progression",
                                   "List of all 5 required SVG assets with artistic brief for each",
                                   "Genre-specific controls list (keyboard + mouse + touch) for the #controls-list in index.html"
                               ]
                           },
                           {
                               "id": "GAME-2",
                               "title": "Generate all 5 SVG art assets: player-sprite, enemy-sprite, tileset, ui-icon-set, promo-keyart",
                               "phase": "concept",
                               "owner_role": "Artist",
                               "required_outputs": [
                                   "player-sprite.svg — playable character, minimum 1 idle pose, expressive silhouette",
                                   "enemy-sprite.svg — enemy / obstacle that fits the genre and opposes the player",
                                   "tileset.svg — world background or floor tile sheet usable as a CSS/canvas background",
                                   "ui-icon-set.svg — icon sprites for pickups, power-ups, or inventory items",
                                   "promo-keyart.svg — cinematic key art (16:9, min 800x450 viewBox) combining all major characters for splash and win screens"
                               ]
                           },
                           {
                               "id": "GAME-3",
                               "title": "Implement splash screen using promo-keyart.svg, genre tag, and animated Start button",
                               "phase": "prototype",
                               "owner_role": "Developer",
                               "required_outputs": [
                                   "#splash overlay fully styled and wired: keyart visible, game-title gradient text, genre-tag, cta-pulse button transitions to title menu",
                                   "promo-keyart.svg displayed at correct aspect ratio with fallback on onerror",
                                   "CSS cta-pulse animation verified in browser"
                               ]
                           },
                           {
                               "id": "GAME-4",
                               "title": "Implement title menu with genre-specific controls list and Play / Settings buttons",
                               "phase": "prototype",
                               "owner_role": "Developer",
                               "required_outputs": [
                                   "#title-menu overlay: #controls-list populated with actual genre controls from GDD",
                                   "#menu-play button starts the game loop",
                                   "#menu-settings stub logs 'settings TODO' (full settings optional stretch goal)"
                               ]
                           },
                           {
                               "id": "GAME-5",
                               "title": "Implement full core game loop: updateFrame(), renderFrame(), entity system, collision detection",
                               "phase": "production",
                               "owner_role": "Developer",
                               "required_outputs": [
                                   "updateFrame(dt): physics, entity movement, AI, collision detection, score increment, lives decrement",
                                   "renderFrame(): Canvas 2D draws tileset.svg as background, enemy-sprite.svg per enemy, player-sprite.svg at player position, ui-icon-set.svg per pickup",
                                   "wireControls(): keyboard + mouse/touch handlers matching GDD controls list",
                                   "triggerWin() and triggerGameOver() called on correct conditions"
                               ]
                           },
                           {
                               "id": "GAME-6",
                               "title": "Implement HUD: live score, lives hearts, level indicator, player-sprite.svg avatar",
                               "phase": "production",
                               "owner_role": "Developer",
                               "required_outputs": [
                                   "#hud-score updates every frame via updateHud()",
                                   "#hud-lives shows heart glyphs equal to remaining lives (shows skull at 0)",
                                   "#hud-level shows current level number",
                                   ".hud-avatar displays player-sprite.svg with onerror fallback"
                               ]
                           },
                           {
                               "id": "GAME-7",
                               "title": "Implement pause menu, game-over screen, and win screen with final scores",
                               "phase": "production",
                               "owner_role": "Developer",
                               "required_outputs": [
                                   "Esc/P key and #pause-btn toggle pause state correctly via togglePause()",
                                   "#resume-btn returns to PLAYING state",
                                   "#quit-btn returns to title menu and stops loop",
                                   "#game-over shows #final-score; #retry-btn restarts; #go-to-menu returns to title",
                                   "#win-screen shows #win-score and promo-keyart.svg; both buttons functional"
                               ]
                           },
                           {
                               "id": "GAME-8",
                               "title": "Implement progression system: multi-level difficulty scaling, enemy waves, scoring bonuses",
                               "phase": "production",
                               "owner_role": "Game Designer",
                               "required_outputs": [
                                   "At least 3 levels with increasing difficulty (more enemies, faster speed, or new patterns per GDD)",
                                   "Level-up trigger: clear wave, reach score threshold, or time-based — must match GDD",
                                   "#hud-level increments correctly on level-up",
                                   "Win condition fires only after final level is cleared"
                               ]
                           },
                           {
                               "id": "GAME-9",
                               "title": "Integrate all 5 SVG assets into gameplay: verify tileset background, enemy sprites, player sprite, pickup icons",
                               "phase": "production",
                               "owner_role": "Developer",
                               "required_outputs": [
                                   "tileset.svg used as Canvas drawImage background every renderFrame()",
                                   "enemy-sprite.svg drawn at each enemy entity position",
                                   "player-sprite.svg drawn at player position (distinct from HUD avatar)",
                                   "ui-icon-set.svg drawn at each pickup/item position",
                                   "promo-keyart.svg visible on splash screen and win screen (already wired in scaffold)"
                               ]
                           },
                           {
                               "id": "GAME-10",
                               "title": "Add Web Audio API sound effects and music loop",
                               "phase": "production",
                               "owner_role": "Sound Designer",
                               "required_outputs": [
                                   "AudioContext created on first user gesture to comply with browser autoplay policy",
                                   "At minimum: jump/action sound, hit/damage sound, score pickup sound, game-over sound, win fanfare",
                                   "Background music loop (OscillatorNode or AudioBuffer) that starts on Play and stops on game-over/win",
                                   "All audio gracefully silent if AudioContext is unavailable"
                               ]
                           },
                           {
                               "id": "GAME-11",
                               "title": "QA pass: visual polish, animation, damage flash, win particles, mobile responsiveness",
                               "phase": "qa",
                               "owner_role": "QA",
                               "required_outputs": [
                                   "Player damage flash (red overlay or sprite flash for ~200ms)",
                                   "Win screen particle burst or keyart glow animation",
                                   "Canvas resizes correctly on window resize for 360px–1920px viewports",
                                   "All buttons reachable and functional on mobile touch (min tap target 44px)",
                                   "No uncaught JS exceptions in browser console during full playthrough"
                               ]
                           },
                           {
                               "id": "GAME-12",
                               "title": "Automate Netlify deploy lane, produce itch.io zip, and package Steam Electron/Tauri build",
                               "phase": "release",
                               "owner_role": "Backend Architect",
                               "required_outputs": [
                                   "Netlify deploy triggered and smoke-check passed (HTTP 200 on index.html)",
                                   "itch.io zip bundle: index.html + style.css + game.js + all 5 SVG assets",
                                   "Steam desktop wrapper: Electron or Tauri project wrapping the web build, signed and ready for upload",
                                   "RELEASE_NOTES.md committed with version, changelog, and asset credits"
                               ]
                           }
                       ],
    "readiness_checklist": [
        {
            "id": "nat_traversal",
            "title": "NAT Traversal/Relay Fallback",
            "description": "STUN/TURN relay fallback tested, relay budget alarms configured, P2P connection success rate tracked."
        },
        {
            "id": "host_migration",
            "title": "Host Migration",
            "description": "Session continuity rules defined and tested for host disconnects."
        },
        {
            "id": "relay_budget",
            "title": "Relay Budget Guardrail",
            "description": "Relay usage tracked, coordinator escalation on spend spikes."
        },
        {
            "id": "steam_compliance",
            "title": "Steam Compliance Checklist",
            "description": "Build signing, store assets, QA, and compliance requirements met for Steam release."
        },
        {
            "id": "itch_lane",
            "title": "itch.io Release Lane",
            "description": "Web build tested and ready for itch.io deployment."
        },
        {
            "id": "telemetry",
            "title": "Multiplayer Telemetry Minimum",
            "description": "Match success, disconnect reasons, relay usage, host churn, crash-free sessions tracked."
        }
    ],
    "dependency_graph":  {
                             "GAME-1":  [],
                             "GAME-2":  ["GAME-1"],
                             "GAME-3":  ["GAME-2"],
                             "GAME-4":  ["GAME-2"],
                             "GAME-5":  ["GAME-1", "GAME-2", "GAME-3", "GAME-4"],
                             "GAME-6":  ["GAME-5"],
                             "GAME-7":  ["GAME-5"],
                             "GAME-8":  ["GAME-5"],
                             "GAME-9":  ["GAME-2", "GAME-5"],
                             "GAME-10": ["GAME-5"],
                             "GAME-11": ["GAME-6", "GAME-7", "GAME-8", "GAME-9", "GAME-10"],
                             "GAME-12": ["GAME-11"]
                         }
}

