{
    "template_id":  "publishing_house",
    "display_name":  "Publishing House",
    "version":  "1.0.0",
    "goal_definition":  "Operate an editorial pipeline that consistently publishes high-quality, discoverable content with measurable audience growth.",
    "coordinator_agent":  {
                              "required":  true,
                              "role":  "Coordinator Agent",
                              "system_prompt_profile":  "hiveforge_coordinator_v1",
                              "system_prompt_path":  "agents/prompts/coordinator_system_prompt.md"
                          },
    "subordinate_agents":  [
                               {
                                   "role":  "Editor-in-Chief",
                                   "alias":  "Senior Project Manager",
                                   "required":  true,
                                   "personality_prompt_paths":  [
                                                                    "agency-agents/project-management/project-manager-senior.md"
                                                                ]
                               },
                               {
                                   "role":  "Writer",
                                   "alias":  "Content Creator",
                                   "required":  true,
                                   "personality_prompt_paths":  [
                                                                    "agency-agents/marketing/marketing-content-creator.md"
                                                                ]
                               },
                               {
                                   "role":  "Researcher",
                                   "alias":  "Trend Researcher",
                                   "required":  true,
                                   "personality_prompt_paths":  [
                                                                    "agency-agents/product/product-trend-researcher.md"
                                                                ]
                               },
                               {
                                   "role":  "Proofreader",
                                   "alias":  "Reality Checker",
                                   "required":  true,
                                   "personality_prompt_paths":  [
                                                                    "agency-agents/testing/testing-reality-checker.md"
                                                                ]
                               },
                               {
                                   "role":  "Designer",
                                   "alias":  "Visual Storyteller",
                                   "required":  true,
                                   "personality_prompt_paths":  [
                                                                    "agency-agents/design/design-visual-storyteller.md"
                                                                ]
                               },
                               {
                                   "role":  "Marketing",
                                   "alias":  "Growth Hacker",
                                   "required":  true,
                                   "personality_prompt_paths":  [
                                                                    "agency-agents/marketing/marketing-growth-hacker.md"
                                                                ]
                               }
                           ],
    "optional_agents":  [
                            "Technical Writer",
                            "SEO Specialist",
                            "Brand Guardian",
                            "Feedback Synthesizer",
                            "Legal Compliance Checker"
                        ],
    "role_capabilities":  {
                              "Growth Hacker":  {
                                                    "can_deploy":  true,
                                                    "can_spend":  false,
                                                    "allowed_connectors":  [
                                                                               "github",
                                                                               "netlify",
                                                                               "email_provider",
                                                                               "analytics",
                                                                               "kdp",
                                                                               "gumroad",
                                                                               "substack",
                                                                               "custom_cms"
                                                                           ]
                                                },
                              "Content Creator":  {
                                                     "can_deploy":  false,
                                                     "can_spend":  false,
                                                     "allowed_connectors":  [
                                                                                "github",
                                                                                "analytics"
                                                                            ]
                                                 },
                              "Reality Checker":  {
                                                      "can_deploy":  false,
                                                      "can_spend":  false,
                                                      "allowed_connectors":  [
                                                                                 "analytics",
                                                                                 "github"
                                                                             ]
                                                  }
                          },
    "operating_mode":  "finite_delivery",
    "book_autonomy_contract":  {
                                   "enabled":  true,
                                   "story_bible_required":  true,
                                   "chapter_count":  12,
                                   "continuity_validator":  true,
                                   "humanization_pass":  true,
                                   "feedback_revision_rounds":  2,
                                   "publish_target":  "direct_connector",
                                   "distribution_targets":  [
                                                                "kdp",
                                                                "gumroad",
                                                                "substack",
                                                                "custom_cms"
                                                            ]
                               },
    "recurring_loops":  [
                            {
                                "key":  "publishing_story_bible_loop",
                                "title":  "Generate and refine story bible, themes, and canon",
                                "phase":  "story_architecture",
                                "owner_role":  "Content Creator",
                                "every_ms":  21600000,
                                "enabled":  true
                            },
                            {
                                "key":  "publishing_chapter_draft_loop",
                                "title":  "Draft next chapter from beat sheet and event ledger",
                                "phase":  "chapter_drafting",
                                "owner_role":  "Content Creator",
                                "every_ms":  14400000,
                                "enabled":  true
                            },
                            {
                                "key":  "publishing_editorial_qc",
                                "title":  "Run editorial quality, continuity, and source verification sweep",
                                "phase":  "editing",
                                "owner_role":  "Reality Checker",
                                "every_ms":  21600000,
                                "enabled":  true
                            },
                            {
                                "key":  "publishing_feedback_humanization_loop",
                                "title":  "Apply reader feedback and anti-AI humanization revisions",
                                "phase":  "revision",
                                "owner_role":  "Senior Project Manager",
                                "every_ms":  21600000,
                                "enabled":  true
                            },
                            {
                                "key":  "publishing_release_loop",
                                "title":  "Publish approved manuscript build to distribution pipeline",
                                "phase":  "distribution",
                                "owner_role":  "Growth Hacker",
                                "action":  {
                                               "type":  "connector",
                                               "connector":  "custom_cms",
                                               "operation":  "publish_book",
                                               "estimated_cost":  0,
                                               "input":  {
                                                             "publication":  "book-production",
                                                             "slug":  "weekly-book-release",
                                                             "visibility":  "public",
                                                             "distribution_targets":  [
                                                                                          "custom_cms",
                                                                                          "substack",
                                                                                          "gumroad",
                                                                                          "kdp"
                                                                                      ],
                                                             "distribution_strategy":  "broadcast",
                                                             "required_successes":  2,
                                                             "rollback_on_failure":  true,
                                                             "verify_after_publish":  true
                                                         },
                                               "requires_permission":  false
                                           },
                                "every_ms":  43200000,
                                "enabled":  true
                            }
                        ],
    "auto_staffing_policy":  {
                                 "enabled":  true,
                                 "cooldown_minutes":  90,
                                 "backlog_per_agent_threshold":  3,
                                 "max_optional_adds":  2,
                                 "max_agents":  10
                             },
    "workflow_definition":  {
                                "phases":  [
                                               "story_architecture",
                                               "chapter_planning",
                                               "research",
                                               "chapter_drafting",
                                               "editing",
                                               "revision",
                                               "distribution"
                                           ],
                                "heartbeat_enabled":  true
                            },
    "task_breakdown":  [
                           {
                               "id":  "PUB-1",
                               "title":  "Build story bible, genre constraints, and narrative voice guide",
                               "phase":  "story_architecture"
                           },
                           {
                               "id":  "PUB-2",
                               "title":  "Create chapter beat sheet and event dependency map",
                               "phase":  "chapter_planning"
                           },
                           {
                               "id":  "PUB-3",
                               "title":  "Collect source material, references, and world facts",
                               "phase":  "research"
                           },
                           {
                               "id":  "PUB-4",
                               "title":  "Draft chapter-by-chapter manuscript from beat sheet",
                               "phase":  "chapter_drafting"
                           },
                           {
                               "id":  "PUB-5",
                               "title":  "Run proofing, continuity checks, and style QA",
                               "phase":  "editing"
                           },
                           {
                               "id":  "PUB-6",
                               "title":  "Apply feedback loops and humanization pass",
                               "phase":  "revision"
                           },
                           {
                               "id":  "PUB-7",
                               "title":  "Publish, distribute, and report performance",
                               "phase":  "distribution"
                           }
                       ],
    "dependency_graph":  {
                             "PUB-1":  [

                                       ],
                             "PUB-2":  [
                                           "PUB-1"
                                       ],
                             "PUB-3":  [
                                           "PUB-2"
                                       ],
                             "PUB-4":  [
                                           "PUB-3"
                                       ],
                             "PUB-5":  [
                                           "PUB-4"
                                       ],
                             "PUB-6":  [
                                           "PUB-5"
                                       ],
                             "PUB-7":  [
                                           "PUB-6"
                                       ]
                         }
}

