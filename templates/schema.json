{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HiveForge Template",
  "type": "object",
  "required": [
    "template_id",
    "display_name",
    "version",
    "goal_definition",
    "coordinator_agent",
    "subordinate_agents",
    "optional_agents",
    "workflow_definition",
    "task_breakdown",
    "dependency_graph"
  ],
  "properties": {
    "template_id": {"type": "string"},
    "display_name": {"type": "string"},
    "version": {"type": "string"},
    "goal_definition": {"type": "string"},
    "operating_mode": {
      "type": "string",
      "enum": ["finite_delivery", "continuous_business"]
    },
    "coordinator_agent": {
      "type": "object",
      "required": ["required", "role", "system_prompt_profile", "system_prompt_path"],
      "properties": {
        "required": {"type": "boolean"},
        "role": {"type": "string"},
        "system_prompt_profile": {"type": "string"},
        "system_prompt_path": {"type": "string"}
      }
    },
    "subordinate_agents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["role", "required", "personality_prompt_paths"],
        "properties": {
          "role": {"type": "string"},
          "alias": {"type": "string"},
          "required": {"type": "boolean"},
          "personality_prompt_paths": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string"}
          }
        }
      }
    },
    "optional_agents": {
      "type": "array",
      "items": {"type": "string"}
    },
    "role_capabilities": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "can_deploy": {"type": "boolean"},
          "can_spend": {"type": "boolean"},
          "allowed_connectors": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    },
    "recurring_loops": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "title", "phase", "every_ms"],
        "properties": {
          "key": {"type": "string"},
          "title": {"type": "string"},
          "phase": {"type": "string"},
          "owner_role": {"type": "string"},
          "every_ms": {"type": "integer", "minimum": 60000},
          "action": {
            "type": "object",
            "properties": {
              "type": {"type": "string"},
              "connector": {"type": "string"},
              "operation": {"type": "string"},
              "estimated_cost": {"type": "number", "minimum": 0},
              "requires_permission": {"type": "boolean"},
              "input": {"type": "object"}
            }
          },
          "enabled": {"type": "boolean"}
        }
      }
    },
    "auto_staffing_policy": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "cooldown_minutes": {"type": "integer", "minimum": 1},
        "backlog_per_agent_threshold": {"type": "integer", "minimum": 1},
        "max_optional_adds": {"type": "integer", "minimum": 0},
        "max_agents": {"type": "integer", "minimum": 1}
      }
    },
    "workflow_definition": {
      "type": "object",
      "required": ["phases", "heartbeat_enabled"],
      "properties": {
        "phases": {
          "type": "array",
          "items": {"type": "string"}
        },
        "heartbeat_enabled": {"type": "boolean"}
      }
    },
    "task_breakdown": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "phase"],
        "properties": {
          "id": {"type": "string"},
          "title": {"type": "string"},
          "phase": {"type": "string"}
        }
      }
    },
    "dependency_graph": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {"type": "string"}
      }
    }
  }
}
