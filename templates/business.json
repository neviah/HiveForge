{
    "template_id":  "business",
    "display_name":  "Business",
    "version":  "1.0.0",
    "goal_definition":  "Launch and operate a small-to-mid-size digital business with coordinated product, marketing, finance, and support operations.",
    "coordinator_agent":  {
                              "required":  true,
                              "role":  "Coordinator Agent",
                              "system_prompt_profile":  "hiveforge_coordinator_v1",
                              "system_prompt_path":  "agents/prompts/coordinator_system_prompt.md"
                          },
    "subordinate_agents":  [
                               {
                                   "role":  "CEO",
                                   "required":  true,
                                   "personality_prompt_paths":  [
                                                                    "../agency-agents/specialized/agents-orchestrator.md"
                                                                ]
                               },
                               {
                                   "role":  "PM",
                                   "alias":  "Senior Project Manager",
                                   "required":  true,
                                   "personality_prompt_paths":  [
                                                                    "../agency-agents/project-management/project-manager-senior.md"
                                                                ]
                               },
                               {
                                   "role":  "Developer",
                                   "alias":  "Backend Architect",
                                   "required":  true,
                                   "personality_prompt_paths":  [
                                                                    "../agency-agents/engineering/engineering-backend-architect.md"
                                                                ]
                               },
                               {
                                   "role":  "Designer",
                                   "alias":  "UI Designer",
                                   "required":  true,
                                   "personality_prompt_paths":  [
                                                                    "../agency-agents/design/design-ui-designer.md"
                                                                ]
                               },
                               {
                                   "role":  "Marketing",
                                   "alias":  "Growth Hacker + Content Creator",
                                   "required":  true,
                                   "personality_prompt_paths":  [
                                                                    "../agency-agents/marketing/marketing-growth-hacker.md",
                                                                    "../agency-agents/marketing/marketing-content-creator.md"
                                                                ]
                               },
                               {
                                   "role":  "Support",
                                   "alias":  "Support Responder",
                                   "required":  true,
                                   "personality_prompt_paths":  [
                                                                    "../agency-agents/support/support-support-responder.md"
                                                                ]
                               },
                               {
                                   "role":  "CFO",
                                   "alias":  "Finance Tracker",
                                   "required":  true,
                                   "personality_prompt_paths":  [
                                                                    "../agency-agents/support/support-finance-tracker.md"
                                                                ]
                               }
                           ],
    "optional_agents":  [
                            "Security Engineer",
                            "Reality Checker",
                            "PPC Campaign Strategist",
                            "Brand Guardian",
                            "Legal Compliance Checker",
                            "SEO Specialist",
                            "Analytics Reporter"
                        ],
    "role_capabilities":  {
                              "Growth Hacker + Content Creator":  {
                                                                  "can_deploy":  false,
                                                                  "can_spend":  true,
                                                                  "allowed_connectors":  [
                                                                                             "google_ads",
                                                                                             "analytics"
                                                                                         ]
                                                              },
                              "Support Responder":  {
                                                       "can_deploy":  false,
                                                       "can_spend":  false,
                                                       "allowed_connectors":  [
                                                                                  "email_provider"
                                                                              ]
                                                   },
                              "Finance Tracker":  {
                                                     "can_deploy":  false,
                                                     "can_spend":  true,
                                                     "allowed_connectors":  [
                                                                                "analytics",
                                                                                "stripe",
                                                                                "google_ads"
                                                                            ]
                                                 }
                          },
    "operating_mode":  "continuous_business",
    "recurring_loops":  [
                            {
                                "key":  "business_maintenance_loop",
                                "title":  "Run site/platform maintenance and issue triage",
                                "phase":  "maintenance",
                                "owner_role":  "Backend Architect",
                                "every_ms":  7200000,
                                "enabled":  true
                            },
                            {
                                "key":  "business_ads_loop",
                                "title":  "Review ad spend pacing and optimize campaigns",
                                "phase":  "marketing",
                                "owner_role":  "Growth Hacker + Content Creator",
                                "every_ms":  10800000,
                                "enabled":  true
                            },
                            {
                                "key":  "business_support_loop",
                                "title":  "Process support backlog and improve customer FAQ",
                                "phase":  "support",
                                "owner_role":  "Support Responder",
                                "every_ms":  5400000,
                                "enabled":  true
                            },
                            {
                                "key":  "business_analytics_loop",
                                "title":  "Analyze KPI trends and propose growth actions",
                                "phase":  "analytics",
                                "owner_role":  "Finance Tracker",
                                "every_ms":  14400000,
                                "enabled":  true
                            }
                        ],
    "auto_staffing_policy":  {
                                 "enabled":  true,
                                 "cooldown_minutes":  45,
                                 "backlog_per_agent_threshold":  2,
                                 "max_optional_adds":  4,
                                 "max_agents":  14
                             },
    "workflow_definition":  {
                                "phases":  [
                                               "strategy",
                                               "product_build",
                                               "launch",
                                               "growth",
                                               "optimization"
                                           ],
                                "heartbeat_enabled":  true
                            },
    "task_breakdown":  [
                           {
                               "id":  "BIZ-1",
                               "title":  "Define offer and revenue model",
                               "phase":  "strategy"
                           },
                           {
                               "id":  "BIZ-2",
                               "title":  "Build core product and landing site",
                               "phase":  "product_build"
                           },
                           {
                               "id":  "BIZ-3",
                               "title":  "Set up analytics and payment rails",
                               "phase":  "product_build"
                           },
                           {
                               "id":  "BIZ-4",
                               "title":  "Execute launch campaign",
                               "phase":  "launch"
                           },
                           {
                               "id":  "BIZ-5",
                               "title":  "Run retention and support loops",
                               "phase":  "growth"
                           },
                           {
                               "id":  "BIZ-6",
                               "title":  "Optimize CAC/LTV and budget",
                               "phase":  "optimization"
                           }
                       ],
    "dependency_graph":  {
                             "BIZ-1":  [

                                       ],
