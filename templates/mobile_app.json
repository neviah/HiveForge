{
  "template_id": "mobile_app",
  "display_name": "Mobile App",
  "version": "1.0.0",
  "goal_definition": "Deliver production-grade cross-platform mobile apps with React Native, Expo, QA, and release-readiness automation.",
  "coordinator_agent": {
    "required": true,
    "role": "Coordinator Agent",
    "system_prompt_profile": "hiveforge_coordinator_v1",
    "system_prompt_path": "agents/prompts/coordinator_system_prompt.md"
  },
  "subordinate_agents": [
    {
      "role": "CTO",
      "alias": "Backend Architect",
      "required": true,
      "personality_prompt_paths": [
        "agency-agents/engineering/engineering-backend-architect.md"
      ]
    },
    {
      "role": "Mobile Dev",
      "alias": "Frontend Developer",
      "required": true,
      "personality_prompt_paths": [
        "agency-agents/engineering/engineering-frontend-developer.md"
      ]
    },
    {
      "role": "QA",
      "alias": "Reality Checker",
      "required": true,
      "personality_prompt_paths": [
        "agency-agents/testing/testing-reality-checker.md"
      ]
    },
    {
      "role": "DevOps",
      "alias": "DevOps Automator",
      "required": true,
      "personality_prompt_paths": [
        "agency-agents/engineering/engineering-devops-automator.md"
      ]
    },
    {
      "role": "PM",
      "alias": "Senior Project Manager",
      "required": true,
      "personality_prompt_paths": [
        "agency-agents/project-management/project-manager-senior.md"
      ]
    }
  ],
  "optional_agents": [
    "Security Engineer",
    "API Tester",
    "Incident Response Commander",
    "Technical Writer",
    "Feedback Synthesizer",
    "Sprint Prioritizer",
    "Performance Benchmarker"
  ],
  "role_capabilities": {
    "DevOps Automator": {
      "can_deploy": true,
      "can_spend": true,
      "allowed_connectors": [
        "github",
        "analytics",
        "google_play"
      ]
    },
    "Reality Checker": {
      "can_deploy": false,
      "can_spend": false,
      "allowed_connectors": [
        "analytics"
      ]
    },
    "Backend Architect": {
      "can_deploy": false,
      "can_spend": false,
      "allowed_connectors": [
        "github",
        "supabase"
      ]
    }
  },
  "operating_mode": "continuous_business",
  "recurring_loops": [
    {
      "key": "mobile_release_readiness",
      "title": "Run mobile release readiness and rollback check",
      "phase": "deployment",
      "owner_role": "DevOps Automator",
      "every_ms": 10800000,
      "action": {
        "type": "connector",
        "connector": "github",
        "operation": "list_repos",
        "estimated_cost": 0,
        "requires_permission": false
      },
      "enabled": true
    },
    {
      "key": "mobile_quality_review",
      "title": "Review crash/performance telemetry and UX friction",
      "phase": "maintenance",
      "owner_role": "Reality Checker",
      "every_ms": 14400000,
      "action": {
        "type": "connector",
        "connector": "analytics",
        "operation": "get_profile",
        "estimated_cost": 0,
        "requires_permission": false
      },
      "enabled": true
    }
  ],
  "auto_staffing_policy": {
    "enabled": true,
    "cooldown_minutes": 30,
    "backlog_per_agent_threshold": 2,
    "max_optional_adds": 5,
    "max_agents": 16
  },
  "workflow_definition": {
    "phases": [
      "discovery",
      "implementation",
      "testing",
      "deployment",
      "maintenance"
    ],
    "heartbeat_enabled": true
  },
  "task_breakdown": [
    {
      "id": "MOB-1",
      "title": "Capture requirements and mobile technical design",
      "phase": "discovery"
    },
    {
      "id": "MOB-2",
      "title": "Implement React Native + Expo mobile features",
      "phase": "implementation"
    },
    {
      "id": "MOB-3",
      "title": "Execute QA, security, and performance checks",
      "phase": "testing"
    },
    {
      "id": "MOB-4",
      "title": "Prepare Android packaging runbook and verify",
      "phase": "deployment"
    },
    {
      "id": "MOB-5",
      "title": "Submit AAB to Play Store internal testing track",
      "phase": "deployment"
    },
    {
      "id": "MOB-6",
      "title": "Operate, monitor, and iterate",
      "phase": "maintenance"
    }
  ],
  "dependency_graph": {
    "MOB-1": [],
    "MOB-2": ["MOB-1"],
    "MOB-3": ["MOB-2"],
    "MOB-4": ["MOB-3"],
    "MOB-5": ["MOB-4"],
    "MOB-6": ["MOB-5"]
  }
}
