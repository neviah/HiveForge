    {"id": "RND-3", "title": "Analyze findings and generate insights", "phase": "analysis"},
    {"id": "RND-4", "title": "Run reviewer challenge and corrections", "phase": "peer_review"},
    {"id": "RND-5", "title": "Publish report and recommendations", "phase": "publication"}
  ],
  "dependency_graph": {
    "RND-1": [],
    "RND-2": ["RND-1"],
    "RND-3": ["RND-2"],
    "RND-4": ["RND-3"],
    "RND-5": ["RND-4"]
  }
