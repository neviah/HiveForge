{
  "template_id": "research_lab",
  "display_name": "Research Lab",
  "version": "1.0.0",
  "goal_definition": "Run repeatable research workflows that produce validated findings, clear reports, and actionable recommendations.",
  "coordinator_agent": {
    "required": true,
    "role": "Coordinator Agent",
    "system_prompt_profile": "hiveforge_coordinator_v1"
  },
  "subordinate_agents": [
    {"role": "Lead Scientist", "alias": "Trend Researcher", "required": true, "personality_prompt_path": null},
    {"role": "Researcher", "alias": "Trend Researcher", "required": true, "personality_prompt_path": null},
    {"role": "Data Analyst", "alias": "Analytics Reporter", "required": true, "personality_prompt_path": null},
    {"role": "Writer", "alias": "Technical Writer", "required": true, "personality_prompt_path": null},
    {"role": "Reviewer", "alias": "Reality Checker", "required": true, "personality_prompt_path": null}
  ],
  "optional_agents": [
    "Feedback Synthesizer",
    "Sprint Prioritizer",
    "Legal Compliance Checker",
    "Brand Guardian",
