{
    "template_id":  "software_agency",
    "display_name":  "Software Agency",
    "version":  "1.0.0",
    "goal_definition":  "Deliver production-grade software projects with reliable deployment, QA, and operational excellence.",
    "coordinator_agent":  {
                              "required":  true,
                              "role":  "Coordinator Agent",
                              "system_prompt_profile":  "hiveforge_coordinator_v1",
                              "system_prompt_path":  "agents/prompts/coordinator_system_prompt.md"
                          },
    "subordinate_agents":  [
                               {
                                   "role":  "CTO",
                                   "alias":  "Backend Architect",
                                   "required":  true,
                                   "personality_prompt_paths":  [
                                                                    "../agency-agents/engineering/engineering-backend-architect.md"
                                                                ]
                               },
                               {
                                   "role":  "Backend Dev",
                                   "alias":  "Backend Architect",
                                   "required":  true,
                                   "personality_prompt_paths":  [
                                                                    "../agency-agents/engineering/engineering-backend-architect.md"
                                                                ]
                               },
                               {
                                   "role":  "Frontend Dev",
                                   "alias":  "Frontend Developer",
                                   "required":  true,
                                   "personality_prompt_paths":  [
                                                                    "../agency-agents/engineering/engineering-frontend-developer.md"
                                                                ]
                               },
                               {
                                   "role":  "QA",
                                   "alias":  "Reality Checker",
                                   "required":  true,
                                   "personality_prompt_paths":  [
                                                                    "../agency-agents/testing/testing-reality-checker.md"
                                                                ]
                               },
                               {
                                   "role":  "DevOps",
                                   "alias":  "DevOps Automator",
                                   "required":  true,
                                   "personality_prompt_paths":  [
                                                                    "../agency-agents/engineering/engineering-devops-automator.md"
                                                                ]
                               },
                               {
                                   "role":  "PM",
                                   "alias":  "Senior Project Manager",
                                   "required":  true,
                                   "personality_prompt_paths":  [
                                                                    "../agency-agents/project-management/project-manager-senior.md"
                                                                ]
                               }
                           ],
    "optional_agents":  [
                            "Security Engineer",
                            "API Tester",
                            "Incident Response Commander",
                            "Technical Writer",
                            "Feedback Synthesizer",
                            "Sprint Prioritizer",
                            "Performance Benchmarker"
                        ],
    "role_capabilities":  {
                              "DevOps Automator":  {
                                                      "can_deploy":  true,
                                                      "can_spend":  true,
                                                      "allowed_connectors":  [
                                                                                 "netlify",
                                                                                 "github",
                                                                                 "analytics"
                                                                             ]
                                                  },
                              "Reality Checker":  {
                                                     "can_deploy":  false,
                                                     "can_spend":  false,
                                                     "allowed_connectors":  [
                                                                                "analytics"
                                                                            ]
                                                 },
                              "Backend Architect":  {
                                                       "can_deploy":  false,
                                                       "can_spend":  false,
                                                       "allowed_connectors":  [
                                                                                  "github"
                                                                              ]
                                                   }
                          },
    "operating_mode":  "continuous_business",
    "recurring_loops":  [
                            {
                                "key":  "agency_deploy_pipeline",
                                "title":  "Run deployment readiness, deploy checks, and rollback audit",
                                "phase":  "deployment",
                                "owner_role":  "DevOps Automator",
                                "every_ms":  10800000,
                                "action":  {
                                               "type":  "connector",
                                               "connector":  "netlify",
                                               "operation":  "list_sites",
                                               "estimated_cost":  0,
                                               "requires_permission":  false
                                           },
                                "enabled":  true
                            },
                            {
                                "key":  "agency_incident_review",
                                "title":  "Review incidents, error budgets, and reliability actions",
                                "phase":  "maintenance",
                                "owner_role":  "Reality Checker",
                                "every_ms":  14400000,
                                "action":  {
                                               "type":  "connector",
                                               "connector":  "analytics",
                                               "operation":  "get_profile",
                                               "estimated_cost":  0,
                                               "requires_permission":  false
                                           },
                                "enabled":  true
                            }
                        ],
    "auto_staffing_policy":  {
                                 "enabled":  true,
                                 "cooldown_minutes":  30,
                                 "backlog_per_agent_threshold":  2,
                                 "max_optional_adds":  5,
                                 "max_agents":  16
                             },
    "workflow_definition":  {
                                "phases":  [
                                               "discovery",
                                               "implementation",
                                               "testing",
                                               "deployment",
                                               "maintenance"
                                           ],
                                "heartbeat_enabled":  true
                            },
    "task_breakdown":  [
                           {
                               "id":  "SWE-1",
                               "title":  "Capture requirements and technical design",
                               "phase":  "discovery"
                           },
                           {
                               "id":  "SWE-2",
                               "title":  "Implement backend and frontend features",
                               "phase":  "implementation"
                           },
                           {
                               "id":  "SWE-3",
                               "title":  "Execute QA, security, and performance checks",
                               "phase":  "testing"
                           },
                           {
                               "id":  "SWE-4",
                               "title":  "Deploy to target environment and verify",
                               "phase":  "deployment"
                           },
                           {
                               "id":  "SWE-5",
                               "title":  "Operate, monitor, and iterate",
                               "phase":  "maintenance"
                           }
                       ],
    "dependency_graph":  {
                             "SWE-1":  [

                                       ],
                             "SWE-2":  [
                                           "SWE-1"
                                       ],
                             "SWE-3":  [
                                           "SWE-2"
                                       ],
                             "SWE-4":  [
                                           "SWE-3"
                                       ],
                             "SWE-5":  [
                                           "SWE-4"
                                       ]
                         }
}

